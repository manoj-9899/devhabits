# DevHabits Backend — Environment Config
# Copy to .env and edit as needed

# Port for the local API server
PORT=4224

# Absolute path to the SQLite database file.
# Defaults to <project_root>/data/habits.db if not set.
# DB_PATH=/Users/you/.config/devhabits/habits.db

# Supabase (hosted API — Step 4+; never commit real values)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_key_here
